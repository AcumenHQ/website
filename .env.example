# Get your App ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id

# Resend: waitlist welcome emails (from noreply@acumhq.xyz)
# Get API key at https://resend.com — verify domain acumhq.xyz to send from noreply@acumhq.xyz
RESEND_API_KEY=re_your_resend_api_key

# MongoDB: waitlist storage
# Example: mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=your_mongodb_connection_string
MONGODB_DB_NAME=acumen
